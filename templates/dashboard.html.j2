<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Uwazi · aggregate dashboard</title>

  <!-- Editorial typography — Source Serif 4 body, IBM Plex Mono labels. -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&family=IBM+Plex+Mono:wght@400;500;600&display=swap">

  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>

  <style>
    :root{
      --paper:   #faf8f3;
      --paper-2: #f1ede2;
      --paper-3: #e6e0d0;
      --line:    #d6cfb9;
      --line-2:  #ebe5d2;
      --ink:     #1a1816;
      --ink-2:   #3a3530;
      --dim:     #767064;
      --dimmer:  #a39c8c;
      --accent:  #b86c2c;
      --accent-2:#9c5821;
      --serif: "Source Serif 4", Charter, "Iowan Old Style", Georgia, serif;
      --mono:  "IBM Plex Mono", ui-monospace, "SF Mono", Menlo, monospace;
    }
    *,*::before,*::after{box-sizing:border-box}
    body{margin:0;background:var(--paper);color:var(--ink);
         font:15px/1.55 var(--serif);
         -webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility}

    /* ───── top bar ───── */
    .topbar{display:flex;align-items:center;gap:24px;padding:16px 32px;
            border-bottom:1px solid var(--line);background:var(--paper-2)}
    .brand{display:inline-flex;align-items:center;gap:10px;
           font:600 13px/1 var(--mono);letter-spacing:.06em;color:var(--ink);
           text-transform:uppercase}
    .brand .sq{display:inline-block;width:12px;height:12px;background:var(--ink);
               margin-right:2px}
    .brand .slash{color:var(--dim);font-weight:400}
    .topbar .meta{margin-left:auto;font:11px/1.5 var(--mono);color:var(--dim);
                  letter-spacing:.02em}
    .topbar .meta a{color:var(--accent);text-decoration:none}
    .topbar .meta a:hover{text-decoration:underline}
    .topbar .badge{display:inline-block;padding:2px 7px;border:1px solid var(--line);
                   background:var(--paper);color:var(--dim);font-weight:500;
                   margin-left:8px;letter-spacing:.08em;text-transform:uppercase}

    /* ───── tabs strip (UHRI-style) ───── */
    .tabs{display:flex;gap:0;padding:0 32px;background:var(--paper);
          border-bottom:1px solid var(--line);overflow-x:auto;scrollbar-width:thin}
    .tab{appearance:none;background:transparent;border:0;cursor:pointer;
         padding:14px 18px 12px;margin-bottom:-1px;
         display:inline-flex;align-items:baseline;gap:8px;
         font:500 12px/1.2 var(--mono);letter-spacing:.08em;
         color:var(--dim);text-transform:uppercase;
         border-bottom:2px solid transparent;white-space:nowrap}
    .tab:hover{color:var(--ink)}
    .tab.active{color:var(--ink);border-bottom-color:var(--accent)}
    .tab .tn{font:11px var(--mono);color:var(--dimmer);font-variant-numeric:tabular-nums}
    .tab.active .tn{color:var(--accent-2)}

    /* ───── KPI strip ───── */
    .kpis{display:flex;gap:0;border-bottom:1px solid var(--line);background:var(--paper)}
    .kpi{flex:1;padding:18px 24px;border-right:1px solid var(--line-2);min-width:160px}
    .kpi:last-child{border-right:0}
    .kpi .lbl{font:10px/1 var(--mono);letter-spacing:.14em;color:var(--dim);
              text-transform:uppercase;margin-bottom:8px}
    .kpi .val{font:600 28px/1.1 var(--serif);color:var(--ink);
              font-variant-numeric:tabular-nums}
    .kpi .sub{font:10px/1.4 var(--mono);color:var(--dimmer);margin-top:6px;
              letter-spacing:.02em}

    /* ───── main grid ───── */
    main{padding:24px 32px 48px;max-width:1480px;margin:0 auto}
    .section-head{display:flex;align-items:baseline;gap:12px;
                  margin:8px 0 14px;padding-bottom:8px;
                  border-bottom:1px dotted var(--line)}
    .section-head h2{margin:0;font:600 14px/1 var(--mono);letter-spacing:.12em;
                     color:var(--ink);text-transform:uppercase}
    .section-head .n{font:10px var(--mono);color:var(--dim);letter-spacing:.06em}

    .grid{display:grid;grid-template-columns:repeat(auto-fit, minmax(440px, 1fr));gap:18px}
    .card{background:#fff;border:1px solid var(--line);padding:16px 18px;
          display:flex;flex-direction:column;min-height:340px}
    .card-head{display:flex;align-items:baseline;gap:10px;margin-bottom:6px}
    .card-head .idx{font:500 11px/1 var(--mono);letter-spacing:.12em;color:var(--dimmer)}
    .card-head h3{margin:0;font:600 13px/1.3 var(--serif);color:var(--ink);flex:1}
    .card .n{font:10px/1.4 var(--mono);color:var(--dim);letter-spacing:.06em;
             margin-bottom:10px;text-transform:uppercase}
    .card .canvas-wrap{flex:1;position:relative;min-height:240px}
    .card .empty{color:var(--dim);font-style:italic;padding:48px 0;text-align:center;
                 font:13px var(--serif)}

    /* ───── per-card controls (toggle + csv) ───── */
    .card .ctrl{display:flex;align-items:center;gap:6px;margin-left:auto}
    .card .ctrl button,.card .ctrl a{appearance:none;background:transparent;
        border:1px solid var(--line);padding:3px 8px;cursor:pointer;
        font:10px/1 var(--mono);letter-spacing:.08em;color:var(--dim);
        text-transform:uppercase;text-decoration:none;border-radius:0}
    .card .ctrl button:hover,.card .ctrl a:hover{color:var(--ink);border-color:var(--ink-2)}
    .card .ctrl button.on{background:var(--ink);color:var(--paper);border-color:var(--ink)}
    .card .ctrl .seg{display:inline-flex}
    .card .ctrl .seg button{border-right-width:0}
    .card .ctrl .seg button:last-child{border-right-width:1px}

    /* ───── tab panes ───── */
    .pane[hidden]{display:none}

    /* ───── footer ───── */
    footer{padding:20px 32px;border-top:1px solid var(--line);
           background:var(--paper-2);color:var(--dim);
           font:11px/1.6 var(--mono);letter-spacing:.02em}
    footer .row{display:flex;flex-wrap:wrap;gap:24px;align-items:baseline;
                max-width:1480px;margin:0 auto}
    footer a{color:var(--accent);text-decoration:none}
    footer a:hover{text-decoration:underline}
    footer .credit{margin-left:auto;color:var(--dimmer)}

    @media (max-width: 720px){
      .topbar{flex-wrap:wrap;gap:12px;padding:12px 18px}
      .topbar .meta{margin-left:0;width:100%}
      .tabs{padding:0 18px}
      .tab{padding:12px 12px 10px}
      .kpis{flex-wrap:wrap}
      .kpi{flex-basis:50%;border-bottom:1px solid var(--line-2)}
      main{padding:18px}
      .grid{grid-template-columns:1fr}
      .card{min-height:300px}
    }
  </style>
</head>
<body>

<header class="topbar">
  <span class="brand">
    <span class="sq"></span>UWAZI<span class="slash">/</span>aggregate
    <span class="badge">β</span>
  </span>
  <div class="meta">
    <a href="{{ instance_url }}">{{ instance_url }}</a>
    &nbsp;·&nbsp; generated {{ generated_at }}
  </div>
</header>

{% if tabs|length > 1 %}
<nav class="tabs" role="tablist" aria-label="Templates">
  {% for t in tabs %}
    <button type="button" class="tab {% if loop.first %}active{% endif %}"
            role="tab" aria-selected="{% if loop.first %}true{% else %}false{% endif %}"
            data-tab="{{ t.slug }}">
      {{ t.name }}
      <span class="tn">{{ '{:,}'.format(t.count) }}</span>
    </button>
  {% endfor %}
</nav>
{% endif %}

{% for t in tabs %}
<section class="pane" id="pane-{{ t.slug }}" role="tabpanel"
         aria-label="{{ t.name }}" {% if not loop.first %}hidden{% endif %}>

  {% if t.kpis %}
  <div class="kpis">
    {% for k in t.kpis %}
      <div class="kpi">
        <div class="lbl">{{ k.label }}</div>
        <div class="val">{{ k.value }}</div>
        {% if k.sub %}<div class="sub">{{ k.sub }}</div>{% endif %}
      </div>
    {% endfor %}
  </div>
  {% endif %}

  <main>
    <div class="section-head">
      <h2>Breakdowns</h2>
      <span class="n">
        {{ t.charts|length }} chart{% if t.charts|length != 1 %}s{% endif %}
        · {{ '{:,}'.format(t.count) }} entities
        {% if t.name != "All" %} · <em>{{ t.name }}</em> template{% endif %}
      </span>
    </div>

    <div class="grid">
      {% for c in t.charts %}
        {% set has_data = c.values or c.datasets %}
        {% set can_scale = c.kind in ("bar", "stacked_bar") %}
        <div class="card" data-chart-card="{{ c.id }}">
          <div class="card-head">
            <span class="idx">{{ "%02d"|format(loop.index) }}</span>
            <h3>{{ c.title }}</h3>
            {% if has_data %}
            <div class="ctrl">
              {% if can_scale %}
              <span class="seg" role="group" aria-label="Scale">
                <button type="button" class="on" data-scale="abs"
                        data-target="{{ c.id }}" title="Absolute counts">#</button>
                <button type="button" data-scale="pct"
                        data-target="{{ c.id }}" title="Percent of total">%</button>
              </span>
              {% endif %}
              <a href="#" data-csv="{{ c.id }}" title="Download chart data as CSV">CSV</a>
            </div>
            {% endif %}
          </div>
          <div class="n">n = {{ '{:,}'.format(c.n) }}
            {%- if c.kind in ("bar", "doughnut") %} · {{ c.labels|length }} categories
            {%- elif c.kind == "stacked_bar" %} · {{ c.datasets|length }} series · {{ c.labels|length }} years
            {%- endif %}</div>
          {% if has_data %}
            <div class="canvas-wrap"><canvas id="chart-{{ c.id }}" data-chart-id="{{ c.id }}"></canvas></div>
          {% else %}
            <div class="empty">no data for this field</div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </main>
</section>
{% endfor %}

<footer>
  <div class="row">
    <span>Built with <a href="https://github.com/lszoszk/uwazi-charts">uwazi-charts</a></span>
    <span>· data: <a href="{{ instance_url }}">{{ instance_url }}</a></span>
    <span>· methodology: aggregations only, no content republished</span>
    <span class="credit">generated {{ generated_at }}</span>
  </div>
</footer>

<script>
  const CHARTS = {{ all_charts_json|safe }};

  const SINGLE = "#b86c2c";
  const SINGLE_LINE = "#9c5821";
  // Series ramp for stacked bars + doughnut slices. Hand-picked for legibility
  // against the cream paper background — high-contrast first, then muted fill.
  const RAMP = ["#b86c2c","#3a3530","#9c5821","#767064","#d6cfb9","#a39c8c","#1a1816"];

  // Chart.js doesn't auto-resize canvases that were hidden at construction
  // time, so we lazy-init each chart the first time its tab becomes active.
  const _byId = new Map(CHARTS.map(c => [c.id, c]));
  const _instances = new Map();   // chartId → Chart.js instance
  const _scale = new Map();       // chartId → "abs" | "pct"

  function fmtNum(v) {
    return Number.isInteger(v) ? v.toLocaleString() : v.toFixed(1);
  }

  function colTotals(c) {
    // For stacked: total per x-bucket. Used for percent normalisation.
    if (c.kind !== "stacked_bar") return null;
    return c.labels.map((_, i) =>
      c.datasets.reduce((s, ds) => s + (ds.values[i] || 0), 0));
  }

  function toPct(values, total) {
    if (!total) return values.map(() => 0);
    return values.map(v => (v / total) * 100);
  }

  function datasetsFor(c, scale) {
    if (c.kind === "stacked_bar") {
      const totals = colTotals(c);
      return c.datasets.map((ds, i) => ({
        label: ds.label,
        data: scale === "pct"
          ? ds.values.map((v, j) => totals[j] ? (v / totals[j]) * 100 : 0)
          : ds.values,
        backgroundColor: RAMP[i % RAMP.length],
        borderWidth: 0,
        stack: "s",
      }));
    }
    const isLine = c.kind === "line";
    const isDoughnut = c.kind === "doughnut";
    const sum = c.values.reduce((a, b) => a + b, 0);
    const data = scale === "pct" ? toPct(c.values, sum) : c.values;
    return [{
      label: c.title,
      data,
      backgroundColor: isDoughnut
        ? c.labels.map((_, i) => RAMP[i % RAMP.length])
        : SINGLE,
      borderColor: isLine ? SINGLE_LINE : undefined,
      borderWidth: isLine ? 2 : 0,
      tension: 0.15,
      pointRadius: isLine ? 3 : 0,
      pointBackgroundColor: SINGLE_LINE,
      fill: false,
    }];
  }

  function buildChart(c) {
    if (_instances.has(c.id)) return;
    const el = document.getElementById("chart-" + c.id);
    if (!el) return;
    const hasData = c.kind === "stacked_bar"
      ? (c.datasets && c.datasets.length)
      : (c.values && c.values.length);
    if (!hasData) return;

    const scale = _scale.get(c.id) || "abs";
    const isLine = c.kind === "line";
    const isDoughnut = c.kind === "doughnut";
    const isStacked = c.kind === "stacked_bar";
    const chartType = isStacked ? "bar" : c.kind;

    const inst = new Chart(el, {
      type: chartType,
      data: { labels: c.labels, datasets: datasetsFor(c, scale) },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        indexAxis: (c.kind === "bar") ? "y" : "x",
        plugins: {
          legend: { display: isDoughnut || isStacked,
                    labels: { font: { family: "IBM Plex Mono", size: 10 },
                              color: "#3a3530", boxWidth: 10 } },
          tooltip: {
            backgroundColor: "#1a1816",
            titleFont: { family: "IBM Plex Mono", size: 11 },
            bodyFont:  { family: "IBM Plex Mono", size: 11 },
            padding: 8,
            callbacks: scale === "pct" ? {
              label: ctx => `${ctx.dataset.label}: ${ctx.parsed.y !== undefined
                ? ctx.parsed.y.toFixed(1) : ctx.parsed.toFixed(1)}%`
            } : {},
          },
        },
        scales: isDoughnut ? {} : {
          x: { stacked: isStacked, beginAtZero:true,
               ticks:{precision:0, font:{family:"IBM Plex Mono", size:10}, color:"#767064"},
               grid:{color:"#ebe5d2"} },
          y: { stacked: isStacked, beginAtZero:true,
               max: (scale === "pct" && isStacked) ? 100 : undefined,
               ticks:{autoSkip:false, font:{family:"IBM Plex Mono", size:10}, color:"#3a3530",
                      callback: scale === "pct"
                        ? (v) => v + "%"
                        : undefined},
               grid:{color:"#ebe5d2"} },
        },
      },
    });
    _instances.set(c.id, inst);
  }

  function rebuildChart(c) {
    const existing = _instances.get(c.id);
    if (existing) {
      existing.destroy();
      _instances.delete(c.id);
    }
    buildChart(c);
  }

  function buildVisibleCharts() {
    document.querySelectorAll('.pane:not([hidden]) canvas[data-chart-id]')
      .forEach(el => {
        const c = _byId.get(el.dataset.chartId);
        if (c) buildChart(c);
      });
  }

  // ───── per-card scale toggle (abs / pct) ─────
  document.querySelectorAll('button[data-scale]').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.target;
      const c = _byId.get(id);
      if (!c) return;
      _scale.set(id, btn.dataset.scale);
      // update segmented button state
      document.querySelectorAll(`button[data-target="${id}"]`).forEach(b => {
        b.classList.toggle('on', b.dataset.scale === btn.dataset.scale);
      });
      rebuildChart(c);
    });
  });

  // ───── per-card CSV download ─────
  function csvCell(v) {
    const s = String(v ?? "");
    return /[",\n]/.test(s) ? `"${s.replace(/"/g, '""')}"` : s;
  }

  function chartToCsv(c) {
    if (c.kind === "stacked_bar") {
      const header = ["year", ...c.datasets.map(d => d.label)].map(csvCell).join(",");
      const rows = c.labels.map((y, i) =>
        [y, ...c.datasets.map(d => d.values[i] ?? 0)].map(csvCell).join(","));
      return [header, ...rows].join("\n") + "\n";
    }
    const rows = c.labels.map((l, i) => [l, c.values[i] ?? 0].map(csvCell).join(","));
    return "label,value\n" + rows.join("\n") + "\n";
  }

  document.querySelectorAll('a[data-csv]').forEach(a => {
    a.addEventListener('click', (ev) => {
      ev.preventDefault();
      const c = _byId.get(a.dataset.csv);
      if (!c) return;
      const blob = new Blob([chartToCsv(c)], {type: "text/csv;charset=utf-8"});
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;
      link.download = c.id + ".csv";
      document.body.appendChild(link);
      link.click();
      link.remove();
      setTimeout(() => URL.revokeObjectURL(url), 1000);
    });
  });

  function showTab(slug) {
    document.querySelectorAll('.tab').forEach(btn => {
      const isMatch = btn.dataset.tab === slug;
      btn.classList.toggle('active', isMatch);
      btn.setAttribute('aria-selected', isMatch ? 'true' : 'false');
    });
    document.querySelectorAll('.pane').forEach(pane => {
      pane.hidden = (pane.id !== 'pane-' + slug);
    });
    buildVisibleCharts();
    // URL hash for shareable views
    history.replaceState(null, '', '#tab=' + slug);
  }

  document.querySelectorAll('.tab').forEach(btn => {
    btn.addEventListener('click', () => showTab(btn.dataset.tab));
  });

  // Honour ?tab=… or #tab=… on first load
  const hashTab = (location.hash.match(/tab=([^&]+)/) || [])[1];
  if (hashTab && document.getElementById('pane-' + hashTab)) {
    showTab(hashTab);
  } else {
    buildVisibleCharts();
  }
</script>
</body>
</html>
