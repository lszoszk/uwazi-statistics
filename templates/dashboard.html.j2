<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Uwazi aggregate dashboard</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
  <style>
    :root { --ink:#1a1a1a; --dim:#666; --line:#ddd; --paper:#fafaf7; --accent:#b86c2c; }
    *,*::before,*::after { box-sizing: border-box; }
    body { margin:0; font:14px/1.55 system-ui, sans-serif; color:var(--ink); background:var(--paper); }
    header { padding:24px 32px; border-bottom:1px solid var(--line); background:#fff; }
    header h1 { margin:0 0 4px; font-size:18px; font-weight:600; }
    header .meta { font:11px/1.5 ui-monospace, monospace; color:var(--dim); }
    main { padding:24px 32px; max-width:1400px; margin:0 auto; }
    .grid { display:grid; grid-template-columns:repeat(auto-fit, minmax(420px, 1fr)); gap:18px; }
    .card { background:#fff; border:1px solid var(--line); padding:16px; }
    .card h2 { margin:0 0 8px; font-size:13px; font-weight:600; letter-spacing:.04em; text-transform:uppercase; }
    .card .n { font:10px/1 ui-monospace, monospace; color:var(--dim); margin-bottom:8px; }
    .card .canvas-wrap { position:relative; height:280px; }
    .empty { color:var(--dim); font-style:italic; padding:24px 0; text-align:center; }
    footer { padding:18px 32px; border-top:1px solid var(--line); color:var(--dim); font:11px/1.5 ui-monospace, monospace; }
    footer a { color:var(--accent); }
  </style>
</head>
<body>
  <header>
    <h1>Uwazi aggregate dashboard</h1>
    <div class="meta">
      source: <a href="{{ instance_url }}">{{ instance_url }}</a>
      &middot; entities: {{ '{:,}'.format(total_entities) }}
      &middot; generated: {{ generated_at }}
    </div>
  </header>
  <main>
    <div class="grid">
      {% for c in charts %}
        <div class="card">
          <h2>{{ c.title }}</h2>
          <div class="n">n = {{ '{:,}'.format(c.n) }}</div>
          {% if c.values %}
            <div class="canvas-wrap"><canvas id="chart-{{ c.id }}"></canvas></div>
          {% else %}
            <div class="empty">no data</div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </main>
  <footer>
    Generated by <a href="https://github.com/lszoszk/uwazi-charts">uwazi-charts</a>
    &middot; data fetched once and aggregated client-side &middot;
    please credit the source instance when republishing.
  </footer>

  <script>
    const CHARTS = {{ charts_json|safe }};

    const palette = ["#b86c2c","#2c6bb8","#2cb86c","#b8b62c","#b82c6b","#6c2cb8","#2cb8b6"];

    for (const c of CHARTS) {
      if (!c.values || !c.values.length) continue;
      const el = document.getElementById("chart-" + c.id);
      if (!el) continue;
      const dataset = {
        label: c.title,
        data: c.values,
        backgroundColor: c.kind === "doughnut"
          ? c.labels.map((_, i) => palette[i % palette.length])
          : "#b86c2c",
        borderColor: c.kind === "line" ? "#b86c2c" : undefined,
        borderWidth: c.kind === "line" ? 2 : 1,
        tension: 0.15,
        fill: false,
      };
      new Chart(el, {
        type: c.kind,
        data: { labels: c.labels, datasets: [dataset] },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          indexAxis: c.kind === "bar" ? "y" : "x",
          plugins: {
            legend: { display: c.kind === "doughnut" },
          },
          scales: c.kind === "doughnut" ? {} : {
            x: { beginAtZero: true, ticks: { precision: 0 } },
            y: { ticks: { autoSkip: false } },
          },
        },
      });
    }
  </script>
</body>
</html>
